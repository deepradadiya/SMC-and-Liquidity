# Copy to .env for local development
PORT=3001

# ML API (FastAPI — run: python ml/api.py)
# When running, signals come from XGBoost + RF + SMC ensemble
REACT_APP_ML_API_URL=http://localhost:8000

# Optional: legacy proxy server URL (fallback if ML API is offline)
REACT_APP_PROXY_URL=http://localhost:4000
